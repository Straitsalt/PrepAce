<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Global Library Hub</title>
    <style>
        body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background-color: #0F172A; color: #F1F5F9; }
        .hidden { display: none !important; }
        .nav-bar { background: #1E293B; padding: 15px 20px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #334155; }
        .btn { border: none; padding: 10px 16px; border-radius: 8px; font-weight: bold; cursor: pointer; color: white; font-size: 13px; transition: all 0.2s; }
        .btn-primary { background: #2563EB; }
        .btn-success { background: #10B981; }
        .btn-danger { background: #EF4444; }
        .btn-admin { background: #DC2626; }
        .workspace { padding: 20px; max-width: 900px; margin: 0 auto; display: flex; flex-direction: column; gap: 20px; }
        .card { background: #1E293B; padding: 20px; border-radius: 12px; border: 1px solid #334155; }
        h3, h4 { margin-top: 0; color: #F8FAFC; }
        .form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px; }
        input { padding: 10px; background: #0F172A; border: 1px solid #475569; color: white; border-radius: 8px; }
        .book-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 15px; margin-top: 15px; }
        .book-card { background: #334155; padding: 15px; border-radius: 8px; border: 1px solid #475569; display: flex; flex-direction: column; justify-content: space-between; }
        .admin-log { background: #0F172A; border: 1px solid #EF4444; padding: 15px; border-radius: 8px; margin-top: 20px; }
        .badge { background: #38BDF8; color: #0F172A; padding: 2px 6px; font-size: 11px; font-weight: bold; border-radius: 4px; inline-block; }
    </style>
</head>
<body>

    <div id="authGate" class="workspace" style="margin-top: 80px; max-width: 400px;">
        <div class="card">
            <h3 style="text-align: center; color: #38BDF8;">🔐 SECURE HUB LOGIN</h3>
            <div class="form-group"><label>Username</label><input type="text" id="libUser" placeholder="Enter username"></div>
            <div class="form-group"><label>Password (Must be strong)</label><input type="password" id="libPass" placeholder="Enter password"></div>
            <div style="display: flex; gap: 10px; margin-top: 15px;">
                <button class="btn btn-primary" style="flex: 1;" onclick="gateAccess('login')">Log In</button>
                <button class="btn btn-success" style="flex: 1;" onclick="gateAccess('signup')">Sign Up</button>
            </div>
            <p id="gateError" style="color: #F87171; font-size: 12px; text-align: center; margin-top: 10px;"></p>
        </div>
    </div>

    <div id="libraryApp" class="hidden">
        <div class="nav-bar">
            <h2>📚 Global Library Engine</h2>
            <div>
                <span id="profileTag" style="margin-right: 15px; font-weight: bold; color: #38BDF8;"></span>
                <button class="btn btn-danger" onclick="exitApp()">Logout</button>
            </div>
        </div>

        <div class="workspace">
            <div id="adminPanel" class="card hidden" style="border-color: #10B981;">
                <h4 style="color: #10B981;">⚡ Master Admin Upload Control</h4>
                <div style="display: grid; grid-template-columns: 2fr 2fr 1fr; gap: 10px; align-items: end;">
                    <div class="form-group"><label>Book/PDF Title</label><input type="text" id="bookTitle" placeholder="e.g., Physics Module 1"></div>
                    <div class="form-group"><label>Upload Reference URL / File Marker</label><input type="text" id="bookUrl" placeholder="Paste link or notes descriptor"></div>
                    <button class="btn btn-success" style="height: 40px;" onclick="addBookToGlobalShelf()">Publish Book</button>
                </div>
            </div>

            <div class="card">
                <h3>🌐 Shared Document Reference Library</h3>
                <p style="font-size: 13px; color: #94A3B8; margin: 0;">Everyone can access and read these files. Editing permissions are restricted to the primary system Administrator.</p>
                <div id="globalShelf" class="book-grid">
                    </div>
            </div>

            <div class="card" style="border-color: #38BDF8;">
                <h3 style="color: #38BDF8;">🔒 Your Private Secure Dashboard</h3>
                <p style="font-size: 13px; color: #94A3B8;">This workspace is private to your account profile. Other users cannot see your notes panel layout.</p>
                <div class="form-group">
                    <label>Personal Study Objectives & Notebook Space</label>
                    <textarea id="personalNotes" style="width: 100%; height: 120px; background:#0F172A; color:white; border:1px solid #475569; border-radius:8px; padding:10px; box-sizing: border-box; font-family: inherit; resize: none;" placeholder="Write down formulas, links, or text private to you..." oninput="savePersonalNotes()"></textarea>
                </div>
            </div>

            <div id="masterUserDatabase" class="admin-log hidden">
                <h4 style="color: #EF4444; margin-bottom: 5px;">⚠️ Master Console Account Ledger</h4>
                <p style="font-size: 12px; color: #94A3B8; margin: 0 0 10px 0;">Only you can view this panel. Lists all active registered user account profiles:</p>
                <div id="userListRows" style="font-family: monospace; font-size: 13px; color: #FCA5A5; display: flex; flex-direction: column; gap: 4px;"></div>
            </div>
        </div>
    </div>

    <script>
        // System Data Vault
        let vault = JSON.parse(localStorage.getItem('lib_vault_db')) || { users: {}, globalBooks: [] };
        let activeUser = localStorage.getItem('lib_active_session_user') || null;

        // Force Seed Admin Account on initialization if it doesn't exist
        if (!vault.users['piyush']) {
            vault.users['piyush'] = { password: "adminpassword123", privateNotes: "" };
            localStorage.setItem('lib_vault_db', JSON.stringify(vault));
        }

        function checkSession() {
            if (activeUser) {
                document.getElementById('authGate').classList.add('hidden');
                document.getElementById('libraryApp').classList.remove('hidden');
                document.getElementById('profileTag').innerText = `👤 ${activeUser.toUpperCase()}`;
                
                // Rule 1: Reveal Upload Dashboard ONLY if you log in as admin user 'piyush'
                if(activeUser.toLowerCase() === 'piyush') {
                    document.getElementById('adminPanel').classList.remove('hidden');
                    document.getElementById('masterUserDatabase').classList.remove('hidden');
                    renderUserLedger();
                } else {
                    document.getElementById('adminPanel').classList.add('hidden');
                    document.getElementById('masterUserDatabase').classList.add('hidden');
                }
                
                document.getElementById('personalNotes').value = vault.users[activeUser].privateNotes || "";
                renderShelf();
            } else {
                document.getElementById('authGate').classList.remove('hidden');
                document.getElementById('libraryApp').classList.add('hidden');
            }
        }

        function gateAccess(type) {
            const u = document.getElementById('libUser').value.trim(), p = document.getElementById('libPass').value.trim();
            const err = document.getElementById('gateError');
            if(!u || !p) { err.innerText = "Please complete all authorization entry fields."; return; }
            
            if(type === 'signup') {
                if(vault.users[u]) { err.innerText = "Profile credentials match an existing configuration."; return; }
                if(p.length < 6) { err.innerText = "Password security metrics failed. Must be at least 6 characters."; return; }
                
                vault.users[u] = { password: p, privateNotes: "" };
                localStorage.setItem('lib_vault_db', JSON.stringify(vault));
                err.style.color = "#10B981"; err.innerText = "Account secured successfully! Log in above.";
            } else {
                if(!vault.users[u] || vault.users[u].password !== p) { err.style.color = "#F87171"; err.innerText = "Invalid security credential parameters."; return; }
                activeUser = u; localStorage.setItem('lib_active_session_user', u);
                checkSession();
            }
        }

        function exitApp() { localStorage.removeItem('lib_active_session_user'); activeUser = null; checkSession(); }

        // Rule 1: Admin Adds Book to Global Database Storage
        function addBookToGlobalShelf() {
            const title = document.getElementById('bookTitle').value.trim(), url = document.getElementById('bookUrl').value.trim();
            if(!title || !url) return;
            vault.globalBooks.push({ title: title, url: url, owner: activeUser });
            localStorage.setItem('lib_vault_db', JSON.stringify(vault));
            document.getElementById('bookTitle').value = ''; document.getElementById('bookUrl').value = '';
            renderShelf();
        }

        function deleteBook(idx) {
            vault.globalBooks.splice(idx, 1);
            localStorage.setItem('lib_vault_db', JSON.stringify(vault));
            renderShelf();
        }

        // Rule 2: Everyone can see books, but only Admin can delete
        function renderShelf() {
            const shelf = document.getElementById('globalShelf'); shelf.innerHTML = '';
            if(vault.globalBooks.length === 0) { shelf.innerHTML = '<p style="color:#64748B; font-size:13px;">No reference modules published on shelf yet.</p>'; return; }
            
            vault.globalBooks.forEach((book, index) => {
                let adminDeleteBtn = (activeUser && activeUser.toLowerCase() === 'piyush') 
                    ? `<button class="btn btn-danger" style="padding:4px 8px; font-size:11px; margin-top:10px;" onclick="deleteBook(${index})">Delete</button>` 
                    : '';
                
                shelf.innerHTML += `<div class="book-card">
                    <div>
                        <span class="badge">PDF Book</span>
                        <h4 style="margin: 8px 0 4px 0; font-size:15px;">${book.title}</h4>
                        <p style="font-size:11px; color:#94A3B8; word-break:break-all; margin:0;">Source: ${book.url}</p>
                    </div>
                    <div style="display:flex; justify-content:space-between; align-items:center;">
                        <a href="${book.url.startsWith('http') ? book.url : '#'}" target="_blank" class="btn btn-primary" style="padding:4px 10px; font-size:11px; margin-top:10px; text-decoration:none; text-align:center;">Open/View</a>
                        ${adminDeleteBtn}
                    </div>
                </div>`;
            });
        }

        // Rule 3: Secure unique user space notes saving loop
        function savePersonalNotes() {
            vault.users[activeUser].privateNotes = document.getElementById('personalNotes').value;
            localStorage.setItem('lib_vault_db', JSON.stringify(vault));
        }

        // Rule 4: System Admin sees who registered
        function renderUserLedger() {
            const list = document.getElementById('userListRows'); list.innerHTML = '';
            Object.keys(vault.users).forEach(username => {
                list.innerHTML += `<div>🔹 Account ID: <span style="color:#38BDF8;">${username}</span> (Password: <span style="color:#6366F1;">${vault.users[username].password}</span>)</div>`;
            });
        }

        window.onload = checkSession;
    </script>
</body>
</html>

